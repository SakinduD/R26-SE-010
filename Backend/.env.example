# Supabase Session Pooler (IPv4-compatible — use this for local dev)
# Direct connection is IPv6-only on free tier and won't work on most networks
# IMPORTANT: URL-encode special chars in password (% → %25, # → %23, @ → %40)
# Get from: Supabase Dashboard → Project Settings → Database → Session pooler
DATABASE_URL=postgresql://postgres.omciisubblrjaaronmop:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
SECRET_KEY=change-me
GEMINI_API_KEY=
DEBUG=True

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=r26_se_010

APP_NAME=genz-softskills-api
APP_ENV=development
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=your_groq_api_key_here

# Real LLM mentoring recommendations
# Recommended default for this project: gpt-5-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MENTORING_MODEL=gpt-5-mini
LLM_MENTORING_TIMEOUT_S=45.0

# APM — Adaptive Pedagogical Module
RPE_BASE_URL=http://localhost:8000
APM_SERVICE_TOKEN=change-me-shared-with-rpe   # for RPE→APM session-feedback callback (no JWT context)
APM_WRITE_ANALYTICS=true                       # set false to disable analytics writes from APM
APM_LLM_TIMEOUT_S=8.0
APM_RPE_TIMEOUT_S=5.0

# Supabase Auth
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...         # public anon key (safe for frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc... # SECRET admin key (backend only — never expose)
SUPABASE_JWT_SECRET=your-jwt-secret  # Dashboard → Project Settings → API → JWT Settings
